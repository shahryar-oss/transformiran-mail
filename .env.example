# Delta Mail — environment variable template
# Copy to .env locally; production values live in Render's encrypted env store.
# NEVER commit a real .env file.

# Database (auto-injected on Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
NODE_ENV=production
BASE_URL=https://mail.transformiran.info
PORT=3000

# Session
SESSION_SECRET=generate-a-long-random-string

# Admin / cron auth
SYNC_TOKEN=generate-a-long-random-string

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Transactional email (magic links, briefings)
RESEND_API_KEY=re_...
EMAIL_FROM="Delta Mail <noreply@transformiran.info>"

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://mail.transformiran.info/auth/google/callback
